# Copy to .env and fill in. Reused by training/launcher.py and ui/endpoint.py.
AWS_PROFILE=default
AWS_REGION=us-east-1

# S3 bucket for training data + model artifacts (reuse the mecca-llm bucket or a new one)
BUCKET_NAME=

# SageMaker execution role ARN (the role training jobs + endpoints assume)
SAGEMAKER_ROLE_ARN=

# HuggingFace token — Gemma 3 is GATED, so a read token is required to download it.
# How to get one:
#   1. Create / log in to a HuggingFace account: https://huggingface.co/join
#   2. Accept the Gemma license on BOTH model pages you'll use (one click each;
#      approval is usually instant):
#        - https://huggingface.co/google/gemma-3-4b-it    (cheap dev runs)
#        - https://huggingface.co/google/gemma-3-12b-it   (real run)
#   3. Create a token with READ access:
#        https://huggingface.co/settings/tokens -> "New token" -> type "Read"
#   4. Copy the token (starts with "hf_") and paste it below.
# Verify it works locally:  huggingface-cli login --token $HF_TOKEN
HF_TOKEN=

# Base model for the real run (use gemma-3-4b-it for cheap dev runs)
BASE_MODEL_ID=google/gemma-3-12b-it
